{
  "name": "yhs/webman-config-center",
  "description": "Lightweight, cache-first configuration client for Webman.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.10",
    "nikic/php-parser": "^5.0",
    "symfony/yaml": "^6.4",
    "predis/predis": "^2.2"
  },
  "autoload": {
    "psr-4": {
      "Yhs\\WebmanConfigCenter\\": "src/"
    }
  },
  "bin": [
    "bin/config-center-sync",
    "bin/config-center-listen",
    "bin/config-center-poll"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
}
