#!/usr/bin/env php
<?php

$autoload = $_composer_autoload_path ?? dirname(__DIR__, 3) . '/autoload.php';
require $autoload;

$path = getcwd() . '/config/config-center.php';
if (!is_file($path)) {
    fwrite(STDERR, "缺少 config/config-center.php\n");
    exit(2);
}
$config = require $path;
$interval = max(10, (int) ($config['poll_interval'] ?? 60));
$sync = new Yhs\WebmanConfigCenter\ConfigSynchronizer($config);
while (true) {
    try {
        $sync->syncAll();
    } catch (\Throwable $exception) {
        fwrite(STDERR, 'config-center poll failed: ' . $exception->getMessage() . PHP_EOL);
    }
    sleep($interval);
}

