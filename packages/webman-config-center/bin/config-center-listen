#!/usr/bin/env php
<?php

$autoload = $_composer_autoload_path ?? dirname(__DIR__, 3) . '/autoload.php';
require $autoload;

$path = getcwd() . '/config/config-center.php';
if (!is_file($path)) {
    fwrite(STDERR, "缺少 config/config-center.php\n");
    exit(2);
}
$config = require $path;
(new Yhs\WebmanConfigCenter\RedisEventListener($config, new Yhs\WebmanConfigCenter\ConfigSynchronizer($config)))->run();

